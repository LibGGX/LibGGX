    "xebin": {
        "<dash_ver>": "<file_path>"
    },
    // "gsp" points to a GSP v1 patch (Signature matching)
    "gsp": {
        "1": {
            "search": "",
            "replace": ""
        },
        "2": {
            "search": "",
            "replace": ""
        }
    },
    // "gsp2" points to a GSP v2 patch (PPC Decompiler and instruction matching)
    "gsp2": {
        "1": {
            "search": "",
            "replace": ""
        },
        "2": {
            "search": "",
            "replace": ""
        }
    }
