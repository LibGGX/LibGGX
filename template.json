        "type": "patch",
        // Name not required but useful for frontends
        "name": "<patch_name>",
        // Master version control; If not enabled here, Mandeville will reject it.
        "versions": {
            "1888": false,
            "6717": false,
            "7258": false,
            "9199": false,
            "13604": false,
            "15574": false,
            "17489": false,
            "17559": true
        }
